# ==========================================
# Hermes-ADK 2.0 (Hmsdk) Environment Example
# ==========================================

# 1. Gemini API Key (Required)
# Get a key from Google AI Studio
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# 2. Telegram Bot Configuration (Required)
# Create a bot via @BotFather to get the token, and obtain your chat ID
TELEGRAM_TOKEN="YOUR_TELEGRAM_BOT_TOKEN_HERE"
TELEGRAM_CHAT_ID="YOUR_TELEGRAM_CHAT_ID_HERE"

# 3. Model Overrides (Optional, defaults to gemini-3.5-flash and antigravity-preview-05-2026)
# ORCHESTRATOR_MODEL="gemini-3.5-flash"
# ANTIGRAVITY_MODEL="antigravity-preview-05-2026"

# 4. Redis Overrides (Optional, defaults to localhost:6379)
# REDIS_HOST="localhost"
# REDIS_PORT=6379
# REDIS_DB=0
